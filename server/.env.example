# AURELIUS — Environment Configuration Template
# Copy this file to .env and fill in your values.

# Graph Database (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
# For Neo4j Aura (cloud): neo4j+s://<INSTANCE_ID>.databases.neo4j.io

# Vector Database (ChromaDB)
# IMPORTANT: Docker maps ChromaDB port 8000 (container) → 8001 (host)
# So from the host machine (local dev), connect on port 8001.
CHROMA_HOST=localhost
CHROMA_PORT=8001

# LLM Inference 
# Option A: Groq Cloud (recommended — free tier, ~300 tokens/sec via LPU)
# Get your key at: https://console.groq.com
# Leave empty to use local Ollama instead.
GROQ_API_KEY=

# Option B: Local Ollama (no API key required)
# Run: ollama pull llama3 && ollama serve
OLLAMA_URL=http://localhost:11434/api/generate
LLM_MODEL=llama3

# Server Config 
PORT=8000
HOST=0.0.0.0
